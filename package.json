{
  "name": "launchhub",
  "version": "0.1.0",
  "description": "Launch automation hub — Kiwify webhooks → Sheets / Chatwoot / Mautic / Meta workers",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "tsx watch src/gateway/server.ts",
    "dev:workers": "tsx watch src/workers/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/gateway/server.js",
    "start:workers": "node dist/workers/index.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node-pg-migrate up --migrations-dir src/db/migrations --migration-file-language ts --tsconfig tsconfig.migrate.json",
    "migrate:down": "node-pg-migrate down --migrations-dir src/db/migrations --migration-file-language ts --tsconfig tsconfig.migrate.json",
    "migrate:create": "node-pg-migrate create --migrations-dir src/db/migrations --migration-file-language ts"
  },
  "dependencies": {
    "@bull-board/api": "^7.1.5",
    "@bull-board/fastify": "^7.1.5",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "bullmq": "^5.13.2",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
